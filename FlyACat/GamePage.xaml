<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlyACat.GamePage"
             Title="Fly A Cat">

    <Grid RowDefinitions="Auto, *, Auto" Padding="10" BackgroundColor="#E0F7FA">

        <!-- 顶部信息栏 -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" HorizontalOptions="Center" Margin="0,10,0,20">
            <Label Text=";LEVEL 1" FontSize="26" FontAttributes="Bold" TextColor="#1976D2"/>

            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center" Margin="0,5">
                <Label x:Name="Star1" Text="❤️" FontSize="28"/>
                <Label x:Name="Star2" Text="❤️" FontSize="28"/>
                <Label x:Name="Star3" Text="❤️" FontSize="28"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Label Text="🎯 The remaining cats：" FontSize="18" VerticalOptions="Center"/>
                <Label x:Name="RemainingLabel" Text="5" FontSize="20" FontAttributes="Bold" TextColor="#D32F2F" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="The arrow pointing indicates the flight direction. Click on the cat to launch.！" 
                   FontSize="14" TextColor="#555" FontAttributes="Italic" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- 游戏网格区域 -->
        <Grid x:Name="GameGrid" 
              Grid.Row="1" 
              BackgroundColor="#FFFFFF" 
              Margin="10"
              ColumnSpacing="2" 
              RowSpacing="2">
        </Grid>

        <!-- 底部控制栏 -->
        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20" Margin="0,20">
            <Button Text="🔄 Restar" Clicked="OnRestartClicked" BackgroundColor="#FF9800" TextColor="White" FontAttributes="Bold"/>
            <Button Text="🔙 Return to menu" Clicked="OnBackClicked" BackgroundColor="#9E9E9E" TextColor="White"/>
        </HorizontalStackLayout>

        <!-- 游戏结束覆盖层 -->
        <Frame x:Name="GameOverFrame" 
               IsVisible="False" 
               BackgroundColor="#CC000000" 
               HorizontalOptions="Fill" 
               VerticalOptions="Fill"
               HasShadow="True">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="25" Padding="30">
                <Label x:Name="GameOverText" Text="" FontSize="36" TextColor="White" HorizontalOptions="Center" LineBreakMode="WordWrap" FontAttributes="Bold"/>
                <Label x:Name="GameOverSubText" Text="" FontSize="18" TextColor="#DDD" HorizontalOptions="Center"/>

                <Button x:Name="RetryButton" Text="play again" Clicked="OnRestartClicked" WidthRequest="220" HeightRequest="50" BackgroundColor="#4CAF50" TextColor="White" FontSize="18" CornerRadius="25"/>

                <Button Text="Exit level " Clicked="OnBackClicked" WidthRequest="220" HeightRequest="50" BackgroundColor="Transparent" BorderColor="White" TextColor="White" FontSize="16" CornerRadius="25"/>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>