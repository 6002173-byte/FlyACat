<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlyACat.GamePage"
             Title="Level 1 ">

    <Grid RowDefinitions="Auto, *, Auto" Padding="10" BackgroundColor="#E8F5E9">

        <VerticalStackLayout Grid.Row="0" Spacing="5" HorizontalOptions="Center" Margin="0,10">
            <Label Text="🐈 LEVEL 1" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2E7D32"/>
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label x:Name="Star1" Text="❤️" FontSize="24"/>
                <Label x:Name="Star2" Text="❤️" FontSize="24"/>
                <Label x:Name="Star3" Text="❤️" FontSize="24"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="Cats Left:" FontSize="16"/>
                <Label x:Name="RemainingLabel" Text="5" FontSize="18" FontAttributes="Bold" TextColor="#D32F2F"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Grid x:Name="GameGrid" Grid.Row="1" 
              BackgroundColor="LightGray"
              
              Margin="10" 
              ColumnSpacing="1" 
              RowSpacing="1"
              HorizontalOptions="Center" 
              VerticalOptions="Center"
              WidthRequest="360" 
              HeightRequest="360"
              />
    

            <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20" Margin="0,15">
            <Button Text="🔄 Restart" Clicked="OnRestartClicked" BackgroundColor="#4CAF50" TextColor="White" WidthRequest="120"/>
            <Button Text="🔙 Menu" Clicked="OnBackClicked" BackgroundColor="Orange" TextColor="White" WidthRequest="120"/>
        </HorizontalStackLayout>

        <Border x:Name="GameOverFrame" 
                IsVisible="False" 
                Grid.RowSpan="3" 
                BackgroundColor="#AA000000" 
                StrokeThickness="1">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="25">
                <Label x:Name="GameOverText" Text="SUCCESS!" FontSize="36" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                <Label x:Name="GameOverSubText" Text="You saved all cats!" FontSize="18" TextColor="Red" HorizontalTextAlignment="Center"/>

                <Button x:Name="NextLevelButton" 
                        Text="Next Level ➡️" 
                        IsVisible="False" 
                        Clicked="OnNextLevelClicked" 
                        BackgroundColor="#FF9800" 
                        TextColor="White" 
                        WidthRequest="220" 
                        HeightRequest="60" 
                        FontSize="20" 
                        CornerRadius="30"/>

                <Button Text="Play Again" 
                        Clicked="OnRestartClicked" 
                        BackgroundColor="White" 
                        TextColor="Black" 
                        WidthRequest="220" 
                        HeightRequest="50" 
                        CornerRadius="25"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>