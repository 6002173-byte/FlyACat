<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlyACat.LevelSelectPage"
             Title="Select Level">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center" HorizontalOptions="Center">
        <Label Text="Choose Your Level" TextColor="Blue" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Button Text="Level 1" Clicked="OnLevel1Clicked" WidthRequest="250" HeightRequest="60" BackgroundColor="#4CAF50" CornerRadius="10"/>
        <Button Text="Level 2" Clicked="OnLevel2Clicked" WidthRequest="250" HeightRequest="60" BackgroundColor="#2196F3" CornerRadius="10"/>
        <Button Text="Level 3 " Clicked="OnLevel3Clicked" WidthRequest="250" HeightRequest="60" BackgroundColor="#FF9800" CornerRadius="10"/>
        <Button Text="Back" Clicked="OnBackClicked" WidthRequest="250" Margin="0,20" BackgroundColor="Gray"/>
    </VerticalStackLayout>
</ContentPage>