<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlyACat.MainPage"
             Title="Fly A Cat">

    <VerticalStackLayout 
        Spacing="25" 
        Padding="30"
        VerticalOptions="Center"
        HorizontalOptions="Center">

        <!-- tittle-->
        <Label 
            Text="Fly A Cat"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

        <!-- user card -->
        <Frame BorderColor="LightGray" CornerRadius="15" Padding="15" HasShadow="True">
            <VerticalStackLayout Spacing="15" HorizontalOptions="Center">

                <!-- 头像  -->
                <Image 
                    x:Name="UserAvatar"
                    Source="dotnet_bot.png" 
                    WidthRequest="100" 
                    HeightRequest="100"
                    Aspect="AspectFill"
                    HorizontalOptions="Center">
                    <Image.Clip>
                        <EllipseGeometry RadiusX="50" RadiusY="50" Center="50,50" />
                    </Image.Clip>
                </Image>

                <!-- ID 输入框 -->
                <Entry 
                    x:Name="UserIdEntry"
                    Placeholder="Enter your ID"
                    Text="Player1"
                    HorizontalOptions="Center"
                    WidthRequest="200"
                    TextChanged="OnIdChanged"/>

                <!-- Button group: Take photo & Select picture  -->
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button 
                        Text="📷 Photo"
                        FontSize="12"
                        Padding="10,5"
                        BackgroundColor="#2196F3"
                        TextColor="White"/>
                

                    <Button 
                        Text="️ Gallery"
                        FontSize="12"
                        Padding="10,5"
                        BackgroundColor="#4CAF50"
                        TextColor="White"/>
               
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>


        <!-- function botton -->
        <Button 
            Text="Start Game"
            Clicked="OnStartGameClicked"
            HorizontalOptions="Center"
            WidthRequest="200" />

        <Button 
            Text="Select Level"
            Clicked="OnSelectLevelClicked"
            HorizontalOptions="Center"
            WidthRequest="200"
            BackgroundColor="LightGray"
            TextColor="Black"/>

    </VerticalStackLayout>
</ContentPage>