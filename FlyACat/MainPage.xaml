<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlyACat.MainPage"
             Title="Fly A Cat - HomePage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center" HorizontalOptions="Center">

            <Label Text="Fly A Cat" 
                   FontSize="36" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#2196F3"
                   Margin="0,0,0,10"/>

            <Border Stroke="#DDDDDD"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 20"
                    Padding="25" 
                    BackgroundColor="White"
                    MaximumWidthRequest="350">
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">

                    <Grid WidthRequest="150" HeightRequest="150" HorizontalOptions="Center">
                        <Image x:Name="UserAvatar" 
                               Source="dotnet_bot.png" 
                               Aspect="AspectFill">
                            <Image.Clip>
                                <EllipseGeometry RadiusX="75" RadiusY="75" Center="75,75" />
                            </Image.Clip>
                        </Image>

                        <Border x:Name="CameraOverlay" 
                                IsVisible="False" 
                                BackgroundColor="Black" 
                                StrokeShape="Ellipse"
                                Stroke="Transparent">
                            <Grid>
                                <Image x:Name="PreviewImage" Source="dotnet_bot.png" Opacity="0.7" Aspect="AspectFill"/>
                                <BoxView Color="White" Opacity="0.1" />
                                <Label Text="[ CAMERA ON ]" 
                                       TextColor="White" 
                                       FontSize="11" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       FontAttributes="Bold"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Entry x:Name="UserIdEntry" 
                           Placeholder="Player ID" 
                           Text="Player1" 
                           HorizontalOptions="Center" 
                           WidthRequest="180" 
                           HorizontalTextAlignment="Center"
                           TextChanged="OnIdChanged"/>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Button x:Name="BtnVirtualPhoto" 
                                Text="📷 Photo" 
                                Clicked="OnVirtualCameraClicked" 
                                BackgroundColor="#2196F3" 
                                CornerRadius="10"
                                WidthRequest="100"/>

                        <Button x:Name="BtnCapture" 
                                Text="✔️ Take" 
                                IsVisible="False" 
                                Clicked="OnCaptureClicked" 
                                BackgroundColor="#4CAF50" 
                                CornerRadius="10"
                                WidthRequest="100"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="15" Margin="0,10">
                <Button Text="Start Game" 
                        Clicked="OnStartGameClicked" 
                        WidthRequest="240" 
                        HeightRequest="60" 
                        BackgroundColor="#4CAF50" 
                        FontSize="20" 
                        FontAttributes="Bold"  
                        CornerRadius="30"/>

                <Button Text="Select Level" 
                        Clicked="OnSelectLevelClicked" 
                        WidthRequest="240" 
                        HeightRequest="60" 
                        BackgroundColor="#FF9800" 
                      
                        CornerRadius="30"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>