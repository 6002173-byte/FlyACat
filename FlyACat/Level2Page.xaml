<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlyACat.Level2Page"
             Title="Fly A Cat - Level 2">

    <Grid RowDefinitions="Auto, *, Auto" Padding="10" BackgroundColor="#FCE4EC">
        <VerticalStackLayout Grid.Row="0" Spacing="8" HorizontalOptions="Center" Margin="0,10,0,20">
            <Label Text="🐱 LEVEL 2" FontSize="28" FontAttributes="Bold" TextColor="#C2185B" HorizontalOptions="Center"/>
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Label x:Name="Star1" Text="❤️" FontSize="28"/>
                <Label x:Name="Star2" Text="❤️" FontSize="28"/>
                <Label x:Name="Star3" Text="❤️" FontSize="28"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Label Text="Remaining：" FontSize="18" VerticalOptions="Center"/>
                <Label x:Name="RemainingLabel" Text="9" FontSize="22" FontAttributes="Bold" TextColor="#D32F2F"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Grid x:Name="GameGrid" Grid.Row="1" BackgroundColor="White" Margin="10" ColumnSpacing="1" RowSpacing="1"/>

        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20" Margin="0,20">
            <Button Text="🔄 Restart" Clicked="OnRestartClicked" BackgroundColor="#E91E63" TextColor="White" WidthRequest="120"/>
            <Button Text="🔙 Back" Clicked="OnBackClicked" BackgroundColor="#9E9E9E" TextColor="White" WidthRequest="120"/>
        </HorizontalStackLayout>

        <Border x:Name="GameOverFrame" IsVisible="False" BackgroundColor="#CC000000" HorizontalOptions="Fill" VerticalOptions="Fill" StrokeThickness="0">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                <Label x:Name="GameOverText" Text="" FontSize="32" TextColor="White" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                <Label x:Name="GameOverSubText" Text="" FontSize="18" TextColor="#DDD" HorizontalTextAlignment="Center"/>
                <Button x:Name="NextLevelButton" Text="Next Level ➡️" IsVisible="False" Clicked="OnNextLevelClicked" WidthRequest="220" HeightRequest="55" BackgroundColor="#FF9800" TextColor="White" FontSize="18" CornerRadius="25"/>
                <Button x:Name="RetryButton" Text="Try Again" Clicked="OnRestartClicked" WidthRequest="220" HeightRequest="50" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="25"/>
                <Button Text="Menu" Clicked="OnBackClicked" WidthRequest="220" HeightRequest="50" BackgroundColor="Transparent" BorderColor="White" BorderWidth="1" TextColor="White" CornerRadius="25"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>